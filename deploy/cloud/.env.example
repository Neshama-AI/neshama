# Neshama Cloud Backend - Environment Variables
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────

# JWT secret for authentication tokens (generate with: openssl rand -hex 32)
NESHAMA_JWT_SECRET=change-me-to-a-random-secret

# Admin API key for management endpoints
NESHAMA_ADMIN_KEY=admin-key-change-me

# LLM provider API key (required for hosted conversations)
NESHAMA_LLM_API_KEY=sk-your-openai-key-here

# ── Server ────────────────────────────────────────────

# Listen address (0.0.0.0 for Docker)
NESHAMA_HOST=0.0.0.0

# Listen port
NESHAMA_PORT=8420

# CORS allowed origins (comma-separated, or * for all)
NESHAMA_CORS_ORIGINS=*

# ── LLM Configuration ────────────────────────────────

# Default LLM provider: openai, anthropic, deepseek, minimax
NESHAMA_LLM_PROVIDER=openai

# Default model name
NESHAMA_LLM_MODEL=gpt-4o-mini

# ── Redis ─────────────────────────────────────────────

# Redis URL (for session cache and rate limiting)
NESHAMA_REDIS_URL=redis://redis:6379

# ── Subscription Quotas ──────────────────────────────

# Free tier monthly hosted conversations
NESHAMA_FREE_CONVERSATIONS=1000

# Trial mode conversation count
NESHAMA_TRIAL_CONVERSATIONS=50

# Trial token expiry in hours
NESHAMA_TRIAL_EXPIRY_HOURS=24
